# Dependencies — never commit node_modules (huge folder, auto-installed by npm)
node_modules/

# Production build — generated by "npm run build", not needed in git
dist/

# Vite cache
.vite/

# Environment variables — keep secrets out of GitHub!
.env
.env.local
.env.production

# OS files
.DS_Store        # Mac
Thumbs.db        # Windows

# Editor folders
.vscode/
.idea/

# Logs
npm-debug.log*
yarn-error.log*
