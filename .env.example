# =============================================
# NEURALCHAT — Environment Variables
# Rename this file to .env and fill in values
# =============================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── NEON PostgreSQL (FREE) ────────────────────
# Get from: neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require

# ── NextAuth ──────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=PASTE_GENERATED_SECRET_HERE

# ── GROQ API (FREE - No credit card!) ─────────
# Get from: console.groq.com → API Keys → Create API Key
# Sign up with Google - completely free for students!
GROQ_API_KEY=gsk_your_groq_key_here

# ── Upstash Redis (FREE) ──────────────────────
# Get from: upstash.com → your database → TCP tab → reveal password
REDIS_URL=rediss://default:password@your-host.upstash.io:6379

# ── Google OAuth (OPTIONAL) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AWS S3 (OPTIONAL - for file uploads) ─────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
